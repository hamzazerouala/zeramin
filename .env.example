# ============================================================
# DropShop — Variables d'environnement (copier vers .env)
# ============================================================

# --- Application ---
APP_NAME=DropShop
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# --- Base de données ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=dropshop
DB_USERNAME=root
DB_PASSWORD=

# --- Mail ---
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@dropshop.test"
MAIL_FROM_NAME="${APP_NAME}"

# --- Stripe ---
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=

# --- AliExpress ---
ALIEXPRESS_SCRAPER_ENABLED=true
ALIEXPRESS_FETCHER=http
ALIEXPRESS_TIMEOUT=30
ALIEXPRESS_USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"
ALIEXPRESS_STORE_CURRENCY=EUR
ALIEXPRESS_DEFAULT_MARKUP_COEFFICIENT=2.0
ALIEXPRESS_DEFAULT_MARKUP_FIXED=0

# --- Commission plateforme ---
PLATFORM_FEE=0.05

# --- Taux de change (pour conversion automatique AliExpress → EUR) ---
ALIEXPRESS_FX_TO_STORE_EUR=1.0
ALIEXPRESS_FX_TO_STORE_USD=0.92

# --- Session / Cache ---
SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database

# --- Sanctum ---
SANCTUM_STATEFUL_DOMAINS=localhost:5173

# --- GitHub Actions (secrets à configurer) ---
# CPANEL_HOST        — adresse du serveur cPanel
# CPANEL_PORT        — port SSH (22 ou personnalisé)
# CPANEL_USER        — utilisateur SSH cPanel
# CPANEL_SSH_KEY     — clé privée SSH
# MAINTENANCE_SECRET — secret pour bypass le mode maintenance
# APP_URL            — URL publique de l'application
# VITE_STRIPE_PUBLIC_KEY — clé publique Stripe pour le build frontend
