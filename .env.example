APP_NAME=DropShop
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Europe/Paris
APP_URL=https://yourdomain.com
APP_LOCALE=fr
APP_FALLBACK_LOCALE=en

# URL du SPA / front (CORS + liens emails)
FRONTEND_URL=https://yourdomain.com

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info
LOG_SLACK_WEBHOOK_URL=

# --- Base de données : MySQL natif cPanel ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=username_dropshop
DB_USERNAME=username_drop
DB_PASSWORD=

# --- Adaptations cPanel mutualisé (pas de Redis) ---
CACHE_STORE=apcu
SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=database

# Sanctum / SPA
SANCTUM_STATEFUL_DOMAINS=yourdomain.com
SESSION_DOMAIN=.yourdomain.com

# --- Mail (SendGrid via API SMTP) ---
MAIL_MAILER=smtp
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=apikey
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME="${APP_NAME}"
SENDGRID_API_KEY=

# --- Stripe ---
STRIPE_PUBLIC_KEY=pk_test_xxxx
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# --- AliExpress ---
ALIEXPRESS_SCRAPER_ENABLED=true
ALIEXPRESS_TIMEOUT=30
ALIEXPRESS_USER_AGENT="Mozilla/5.0 (compatible; DropShopBot/1.0)"

# --- Cloudinary (CDN images, optionnel) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Divers ---
MAINTENANCE_SECRET=change_me_random_token
BCRYPT_ROUNDS=12

# --- Frontend (Vite) ---
VITE_API_BASE=/api
VITE_STRIPE_PUBLIC_KEY=pk_test_xxxx
